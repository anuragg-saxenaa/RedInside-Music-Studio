{
  "$schema": "https://railway.app/schema.json",
  "production": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile",
    "rootDirectory": "/",
    "build": {
      "noCache": true
    },
    "environment": {
      "NODE_ENV": "production",
      "PORT": "3000",
      "STORAGE_DRIVER": "local"
    }
  }
}